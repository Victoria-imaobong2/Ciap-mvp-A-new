# ─────────────────────────────────────────────────────────────────────────────
# CIAP MVP — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Local PostgreSQL (default for development)
DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/ciap_db

# Supabase (optional — cloud PostgreSQL alternative)
SUPABASE_URL=
SUPABASE_KEY=

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Encryption ────────────────────────────────────────────────────────────────
# Fernet key for encrypting OAuth tokens at rest in the database.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development   # development | staging | production
DEBUG=true

# ── External Platform APIs ────────────────────────────────────────────────────
# YouTube / Google
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/youtube/callback

# Instagram / Meta
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/instagram/callback

# TikTok
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/tiktok/callback

# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/spotify/callback

# ── Data Ingestion ────────────────────────────────────────────────────────────
# How often to run the platform data ingestion job (in hours)
INGESTION_INTERVAL_HOURS=6

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
